{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/generate/pipe", "destination": "/api/generate/pipe" },
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/validate", "destination": "/api/validate" },
    { "source": "/api/networks", "destination": "/api/networks" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/notify", "destination": "/api/notify" },
    { "source": "/api/address", "destination": "/api/address" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
